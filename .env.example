# ---- Bobby server configuration ----
# Copy to .env and adjust. All values have sane defaults; nothing here is required.

# HTTP/WebSocket port for the backend
PORT=8787

# Where Bobby stores its canonical chat database (the "save all my chats" store).
# Default: ./data/bobby.sqlite relative to the server package.
# BOBBY_DB=/absolute/path/to/bobby.sqlite

# Working directory the harness subprocesses run in (their tools operate here).
# Default: a per-chat sandbox under ./data/workspaces/<chatId>.
# BOBBY_WORKDIR=/absolute/path/to/workdir

# ---- Harness executables (only override if not on PATH) ----
# BOBBY_CLAUDE_BIN=claude
# BOBBY_HERMES_BIN=hermes
# BOBBY_PI_BIN=pi

# Claude permission mode for non-interactive runs.
# One of: default | acceptEdits | bypassPermissions | plan
# "acceptEdits" lets a chat use file tools without prompting. Use "default" to be conservative.
BOBBY_CLAUDE_PERMISSION_MODE=acceptEdits

# ---- Memory / Obsidian ----
# Absolute path to your Obsidian vault. If unset, distillation is disabled.
# OBSIDIAN_VAULT=/Users/you/Obsidian/MainVault

# Subfolder inside the vault where Bobby writes distilled notes.
OBSIDIAN_FOLDER=Bobby

# Which harness Bobby uses to run the memory-distillation LLM pass.
# One of: claude | hermes | pi
BOBBY_DISTILL_HARNESS=claude

# Run distillation automatically after each assistant turn (true/false).
BOBBY_AUTO_DISTILL=false
